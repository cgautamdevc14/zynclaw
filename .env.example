# OpenAI-compatible endpoint exposed by LiteLLM.
OPENAI_BASE_URL=http://localhost:4000/v1
OPENAI_API_KEY=local-dev-key

# Public model alias exposed by LiteLLM.
MODEL=Qwen3.6-27B

# Hugging Face model loaded by vLLM.
VLLM_MODEL=Qwen/Qwen3.6-27B-FP8

# Keep unsupported client parameters from breaking local routes.
LITELLM_DROP_PARAMS=true

# Optional: tune after measuring your host.
VLLM_MAX_MODEL_LEN=262144
VLLM_GPU_MEMORY_UTILIZATION=0.92
VLLM_NUM_SPECULATIVE_TOKENS=2
